# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAMES=db1,db2,db3

# Database TLS/SSL mode:
#   DISABLED        = connect without TLS (useful when self-signed certs break the client)
#   PREFERRED       = client default behavior
#   VERIFY_DISABLED = use TLS but do not verify the server certificate
#   VERIFY_CA       = use TLS and verify with DB_SSL_CA
DB_SSL_MODE=DISABLED
# DB_SSL_CA=/path/to/ca.pem

# S3/MinIO Configuration
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=strongpassword
S3_BUCKET=db-backups
S3_PATH_PREFIX=backups
S3_REGION=us-east-1

# API authentication
BACKUP_API_KEY=change-this-long-random-secret

# Automated backup schedule
# BACKUP_CRON_TIMEZONE is required. Example: Asia/Karachi, UTC
BACKUP_CRON_SCHEDULE=0 2 * * *
BACKUP_CRON_TIMEZONE=Asia/Karachi

# Backup timeout in seconds (default: 3600 = 1 hour)
BACKUP_TIMEOUT=3600

# Keep only the latest N backups per database (0 disables cleanup)
MAX_BACKUPS_PER_DATABASE=30

# Failure notification SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=backups@example.com
SMTP_TO_EMAIL=admin@example.com
# STARTTLS, SSL, or NONE
SMTP_SECURITY=STARTTLS
HOST_EMAIL=host@example.com
