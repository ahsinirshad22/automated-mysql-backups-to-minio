# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAMES=db1,db2,db3

# Database TLS/SSL mode:
#   DISABLED        = connect without TLS (useful when self-signed certs break the client)
#   PREFERRED       = client default behavior
#   VERIFY_DISABLED = use TLS but do not verify the server certificate
#   VERIFY_CA       = use TLS and verify with DB_SSL_CA
DB_SSL_MODE=DISABLED
# DB_SSL_CA=/path/to/ca.pem

# S3/MinIO Configuration
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=strongpassword
S3_BUCKET=db-backups
S3_PATH_PREFIX=backups
S3_REGION=us-east-1

# API authentication
BACKUP_API_KEY=change-this-long-random-secret

# Backup timeout in seconds (default: 3600 = 1 hour)
BACKUP_TIMEOUT=3600
