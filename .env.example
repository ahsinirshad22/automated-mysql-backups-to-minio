# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAMES=db1,db2,db3

# S3/MinIO Configuration
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=strongpassword
S3_BUCKET=db-backups
S3_PATH_PREFIX=backups
S3_REGION=us-east-1

# Cron & Retention Settings
# CRON_SCHEDULE uses standard cron format: minute hour day month weekday
# Examples:
#   0 2 * * *     = Every day at 2:00 AM
#   0 */6 * * *   = Every 6 hours
#   30 3 * * 0    = Every Sunday at 3:30 AM
CRON_SCHEDULE=0 2 * * *

# Retention: Delete backups older than N days (0 = keep forever)
RETENTION_DAYS=30

# Backup timeout in seconds (default: 3600 = 1 hour)
BACKUP_TIMEOUT=3600
